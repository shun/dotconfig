#!/usr/bin/env bash

#!/bin/bash

##############################
# OS detection
#
if [ "$(uname)" == 'Darwin' ]; then
    export OS='Mac'
elif [ "$(expr substr $(uname -s) 1 5)" == 'Linux' ]; then
    export OS='Linux'
elif [ "$(expr substr $(uname -s) 1 10)" == 'MINGW32_NT' ]; then
    export OS='Cygwin'
else
    echo "Your platform ($(uname -a)) is not supported."
    exit 1
fi

##############################
# common alias
#
alias env="env | sort"
alias pt="pt --nogroup -iS"
alias ni="nvr --remote"
alias gc="git checkout"
alias gp="git push origin"
alias gl="git clone"
alias gs='cd $(ghq root)/$(ghq list | peco)'

alias clang11="clang++ -std=c++11"
alias clang14="clang++ -std=c++14"
alias clang17="clang++ -std=c++17"
alias p2="python"
alias p3="python3"
alias d=docker
alias dc=docker-compose
alias sudo="sudo -E "
alias ll="ls -lAv --group-directories-first"
alias vi=nvim

##############################
# common values
#
export EDITOR=nvim

##############################
# settings for each OS
#
if [ $OS = "Mac" ]; then
    export GOROOT=/usr/local/opt/go/libexec
    export PATH="/usr/local/opt/llvm/bin:$PATH"
    alias ll="ls -laG"
    alias l="ls -G"
    source /usr/local/etc/bash_completion.d/git-prompt.sh
    source /usr/local/etc/bash_completion.d/git-completion.bash
    export LDFLAGS="-L/usr/local/opt/llvm/lib"
    export CPPFLAGS="-I/usr/local/opt/llvm/include"
elif [ $OS = "Linux" ];then
    alias sed="/bin/sed"
    alias pbcopy="xsel -ib"
    source /etc/bash_completion.d/git-prompt
fi

##############################
# general settings
#
export PS1='\n\[\e[0;32m\]\u@\h:\[\e[0;36m\]\w $(__git_ps1 " (%s)")\n\[\e[m\]\\$ '

##############################
# local functions
#
ghq-list-fzf() {
  local l=`ghq list | fzf --reverse`
  cd "`ghq root`/${l}"
}
alias gl=ghq-list-fzf

